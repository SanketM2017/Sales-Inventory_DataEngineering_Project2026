   .withColumnRenamed(\"REASON_DESCRIPTION_EN\", \"RETURN_REASON_DESC\")\n\n    # Select ingestion columns\n    df_valid = df_valid.select(\"RETURN_REASON_CODE\", \"RETURN_REASON_DESC\")\n\n    # Count\n    valid_count = df_valid.count()\n\n    # Add audit columns\n    df_final = df_valid \\\n        .withColumn(\"SOURCE_ID\", F.lit(\"LKP File\")) \\\n        .withColumn(\"DataDate\", F.current_date()) \\\n        .withColumn(\"UpdateDate\", F.current_date()) \\\n        .withColumn(\"DW_INSERT_DT\", F.current_timestamp()) \\\n        .withColumn(\"DW_UPDATE_DT\", F.current_timestamp())\n\n    # Write to ingestion — TRUNCATE and LOAD\n    df_final.write.jdbc(\n        url=jdbc_url,\n        table=\"ingestion.RETURN_REASON\",\n        mode=\"overwrite\",\n        properties=jdbc_props\n    )\n\n    # Archive source file\n    move_to_archive(file_path, file_archive, table_name)\n\n    print(f\"RETURN_REASON — Valid: {valid_count}, Rejected: 0\")\n\nelse:\n    print(f\"No file found for {table_name}\")","commandVersion":1,"state":"finished","results":{"type":"listResults","data":[{"type":"ansi","data":"RETURN_REASON — Valid: 5, Rejected: 0\n","name":"stdout","arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{}}],"arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[{"name":"df_raw","typeStr":"pyspark.sql.dataframe.DataFrame","schema":{"fields":[{"metadata":{},"name":"RETURN_REASON_CODE","nullable":true,"type":"integer"},{"metadata":{},"name":"REASON_DESCRIPTION_EN","nullable":true,"type":"string"}],"type":"struct"},"tableIdentifier":null},{"name":"df_valid","typeStr":"pyspark.sql.dataframe.DataFrame","schema":{"fields":[{"metadata":{},"name":"RETURN_REASON_CODE","nullable":true,"type":"integer"},{"metadata":{},"name":"RETURN_REASON_DESC","nullable":true,"type":"string"}],"type":"struct"},"tableIdentifier":null},{"name":"df_final","typeStr":"pyspark.sql.dataframe.DataFrame","schema":{"fields":[{"metadata":{},"name":"RETURN_