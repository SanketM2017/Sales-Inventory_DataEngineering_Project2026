{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-sales-sanket"
		},
		"ABLB_Blob_RAW_FLAT_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'ABLB_Blob_RAW_FLAT'"
		},
		"LS_SRC_Gen2_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_SRC_Gen2'"
		},
		"LS_SRC_SQL_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_SRC_SQL'"
		},
		"LS_SRC_Gen2_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://blobsalessanket.dfs.core.windows.net/"
		},
		"LS_SRC_SQL_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "pcserver7284.database.windows.net"
		},
		"LS_SRC_SQL_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "ASQL_SalesProject_Sanket"
		},
		"LS_SRC_SQL_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sanket"
		},
		"LS_SRC_onprimiceKEyvault_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://kv-salesproject-sanket.vault.azure.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-sales-sanket_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ABLB_Blob_RAW_FLAT_connectionString": {
						"value": "[parameters('ABLB_Blob_RAW_FLAT_connectionString')]"
					},
					"LS_SRC_Gen2_accountKey": {
						"value": "[parameters('LS_SRC_Gen2_accountKey')]"
					},
					"LS_SRC_SQL_password": {
						"value": "[parameters('LS_SRC_SQL_password')]"
					},
					"LS_SRC_Gen2_properties_typeProperties_url": {
						"value": "[parameters('LS_SRC_Gen2_properties_typeProperties_url')]"
					},
					"LS_SRC_SQL_properties_typeProperties_server": {
						"value": "[parameters('LS_SRC_SQL_properties_typeProperties_server')]"
					},
					"LS_SRC_SQL_properties_typeProperties_database": {
						"value": "[parameters('LS_SRC_SQL_properties_typeProperties_database')]"
					},
					"LS_SRC_SQL_properties_typeProperties_userName": {
						"value": "[parameters('LS_SRC_SQL_properties_typeProperties_userName')]"
					},
					"LS_SRC_onprimiceKEyvault_properties_typeProperties_baseUrl": {
						"value": "[parameters('LS_SRC_onprimiceKEyvault_properties_typeProperties_baseUrl')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}