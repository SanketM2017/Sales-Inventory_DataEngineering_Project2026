										"storeSettings": {
											"type": "AzureBlobFSReadSettings",
											"recursive": true,
											"enablePartitionDiscovery": false
										},
										"formatSettings": {
											"type": "DelimitedTextReadSettings"
										}
									}
								},
								{
									"name": "ACT_GEN_LKP",
									"type": "Lookup",
									"dependsOn": [
										{
											"activity": "ACT_GEN_META_FILE2",
											"dependencyConditions": [
												"Succeeded"
											]
