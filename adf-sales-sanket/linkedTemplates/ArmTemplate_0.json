											"dependencyConditions": [
												"Succeeded"
											]
										}
									],
									"userProperties": [],
									"typeProperties": {
										"expression": {
											"value": "@greater(\n    activity('ACT_GEN_META_FILE2').output.lastModified,\n     activity('ACT_GEN_LKP').output.firstRow.max_date\n    )\n",
											"type": "Expression"
										},
										"ifTrueActivities": [
											{
												"name": "ACT_MT_Copy_",
												"type": "Copy",
												"dependsOn": [],
